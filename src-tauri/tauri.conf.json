{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MoonPKM",
  "version": "1.0.0",
  "identifier": "com.reasonofmoon.moonpkm",
  "build": {
    "beforeDevCommand": "",
    "devUrl": "http://localhost:3031",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../out"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "MoonPKM — Vim-based Knowledge Manager",
        "width": 1400,
        "height": 900,
        "minWidth": 960,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "wix": {}
    }
  }
}
